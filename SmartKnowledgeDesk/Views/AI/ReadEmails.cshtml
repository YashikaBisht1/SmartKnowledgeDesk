@model List<SmartKnowledgeDesk.Models.EmailTicket>

<h2>Recent Gmail Support Emails</h2>

@foreach (var email in Model)
{
    <div style="border:1px solid gray;padding:20px;margin:10px;border-radius:10px;">
        <h3>@email.Subject</h3>

        <p><strong>From:</strong> @email.Sender</p>

        <p>@email.Body</p>
    </div>
}
